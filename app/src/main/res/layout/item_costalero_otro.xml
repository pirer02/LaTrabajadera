<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/txtNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre Apellido"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:textSize="17sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/txtAltura"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Altura base: 175 cm"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/txtSuplementos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Suplemento: 0 cm"
        android:textSize="14sp"
        android:textColor="@color/orangeApp"/>

    <TextView
        android:id="@+id/txtAlturaTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Altura Final: 175 cm"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditarSuplementoOtro"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar Suplemento"
            android:textSize="11sp"
            app:strokeColor="@color/grisacio"
            android:textColor="@color/grisacio"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp"
            android:paddingHorizontal="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAceptar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Seleccionar"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/orangeApp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>