<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Nombre del paso -->
        <TextView
            android:id="@+id/txtNombrePaso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del paso"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/orangeApp"/>

        <!-- Hermandad y ciudad -->
        <TextView
            android:id="@+id/txtHermandadCiudad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hermandad - Ciudad"
            android:textSize="14sp"
            android:textColor="@android:color/black"/>

        <!-- Tipo de paso -->
        <TextView
            android:id="@+id/txtTipoPaso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Tipo de paso"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"/>

        <!-- Contenedor de botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Botón editar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarPaso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editar"
                android:textSize="15sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                card_view:cardCornerRadius="8dp"/>

            <!-- 🔴 Botón borrar eliminado, ahora se usará swipe-to-delete -->
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
