<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <TextView
            android:id="@+id/txtNombreCostalero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Apellido"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtAlturaCostalero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Altura: 1,75m"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtSuplementos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Suplementos: 0"
            android:textSize="12sp"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRemoveSuplemento"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="-"
        android:textSize="12sp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        app:cornerRadius="6dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddSuplemento"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="+"
        android:textSize="12sp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:layout_marginEnd="4dp"
        android:backgroundTint="@color/orangeApp"
        android:textColor="@android:color/white"
        app:cornerRadius="6dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEliminarCostalero"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="X"
        android:textSize="12sp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        app:cornerRadius="6dp"/>
</LinearLayout>
