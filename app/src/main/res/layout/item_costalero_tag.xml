<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-content"
    android:layout_width="55dp" android:layout_height="wrap_content"
    android:layout_margin="2dp" app:cardBackgroundColor="#F0F0F0"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:contentPadding="4dp"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal">


    <TextView
        android:id="@+id/txtAlturaCostalero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Altura"
        android:textSize="11sp" android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/txtNombreCostalero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre"
        android:textColor="@android:color/black"
        android:textSize="12sp" android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/txtApellidoCostalero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Apellido"
        android:textSize="11sp" android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        android:singleLine="true"/>
</LinearLayout>

</com.google.android.material.card.MaterialCardView>