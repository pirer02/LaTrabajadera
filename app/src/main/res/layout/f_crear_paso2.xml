<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Cabecera con datos del paso -->
    <LinearLayout
        android:id="@+id/headerDatos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_card"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtCapataz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capataz: "
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/orangeApp"/>

        <TextView
            android:id="@+id/txtTipoPaso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo de Paso: "
            android:textSize="16sp"
            android:textColor="@android:color/black"/>

        <TextView
            android:id="@+id/txtHermandad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hermandad: "
            android:textSize="16sp"
            android:textColor="@android:color/black"/>

        <TextView
            android:id="@+id/txtMaxCostaleros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Número máximo de costaleros: "
            android:textSize="16sp"
            android:textColor="@android:color/black"/>
    </LinearLayout>

    <!-- Lista de costaleros -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCostaleros"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/headerDatos"
        app:layout_constraintBottom_toTopOf="@id/btnAddCostalero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón añadir costalero -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCostalero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Añadir Costalero"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/orangeApp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnContinuar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón continuar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continuar"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/black"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
