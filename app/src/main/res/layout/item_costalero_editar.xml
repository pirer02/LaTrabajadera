<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre Apellido"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:textSize="17sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtAlturaBase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Altura base: 175 cm"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/txtSuplementos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suplemento: 0 cm"
            android:textSize="14sp"
            android:textColor="@color/orangeApp"/>

        <TextView
            android:id="@+id/txtAlturaFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Altura Final: 175 cm"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCambiarSuplemento"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cambiar Suplemento"
            android:textSize="11sp"
            app:strokeColor="@color/grisacio"
            android:textColor="@color/grisacio"
            app:cornerRadius="8dp"
            android:paddingHorizontal="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Asiste?"
            android:textSize="12sp"
            android:layout_marginBottom="-4dp"/>

        <CheckBox
            android:id="@+id/chkAsistencia"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleX="1.5"
            android:scaleY="1.5" />
    </LinearLayout>

</LinearLayout>